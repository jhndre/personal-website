# WHOOP Developer API (create app at https://developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Optional: default is http://localhost:3000/callback
# WHOOP_REDIRECT_URI=http://localhost:3000/callback

# Filled by npm run whoop:auth — do not edit by hand
# WHOOP_ACCESS_TOKEN=
# WHOOP_REFRESH_TOKEN=

# --- Vercel (api/whoop + api/whoop-sync) ---
# Create a KV store in Vercel and add:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# For cron (whoop-sync): set CRON_SECRET and call GET /api/whoop-sync with header: Authorization: Bearer <CRON_SECRET>
# Optional for first sync: set WHOOP_ACCESS_TOKEN and WHOOP_REFRESH_TOKEN so sync can run before KV has tokens


