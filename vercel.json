{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/whoop-data.json", "destination": "/whoop-data.json" },
    { "source": "/:path((?!api/)(?!whoop-data\\.json$).*)", "destination": "/index.html" }
  ],
  "functions": { "api/**/*.ts": { "memory": 128 } },
  "crons": [{ "path": "/api/whoop-sync", "schedule": "*/30 * * * *" }]
}
