{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/((?!api/)(?!whoop-data\\.json$).*)", "destination": "/index.html" }],
  "functions": { "api/**/*.ts": { "memory": 128 } },
  "crons": [{ "path": "/api/whoop-sync", "schedule": "*/30 * * * *" }]
}
